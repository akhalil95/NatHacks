# ============================================================================
# NatHacks Backend - Environment Variables
#
# Copy this file to .env and configure for your environment
# For Docker Compose: Customize and rename to .env for auto-loading
# ============================================================================

# ── Database Configuration ──────────────────────────────────────────────────
# Only needed if using PostgreSQL. Skip if using in-memory storage.
# Docker Compose handles this automatically; uncomment for local dev.

# DATABASE_URL=postgresql://user:password@localhost:5432/appdb

# ── Redis Cache ─────────────────────────────────────────────────────────────
# Only needed if using Redis for caching. Skip for in-memory alternatives.

# REDIS_URL=redis://localhost:6379/0

# ── Google Cloud Vision (Optional) ──────────────────────────────────────────
# Enable fallback detection when MediaPipe isn't confident.
# Get credentials: https://cloud.google.com/docs/authentication/getting-started

# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Gemini AI Assistant (Optional) ──────────────────────────────────────────
# Enable intelligent coaching feedback and contextual guidance.
# Get API key: https://ai.google.dev/tutorials/setup

GEMINI_API_KEY=your_gemini_api_key_here

# ── Vision Pipeline Settings (Optional) ──────────────────────────────────────
# Fine-tune computer vision performance.

# DETECT_SCALE=0.75          # Frame downscale for faster inference (0.0-1.0)
# ARUCO_STRIDE=2             # Process every N frames for ArUco detection
# REDUCE_MOTION=false        # Smooth overlays by averaging across frames

# ── Server Configuration ────────────────────────────────────────────────────

# HOST=0.0.0.0               # Server bind address
# PORT=8000                  # Server port
# WORKERS=4                  # Number of uvicorn workers (for production)

# ── Logging & Debugging ────────────────────────────────────────────────────

# LOG_LEVEL=INFO            # DEBUG, INFO, WARNING, ERROR
# DEBUG=false               # Enable detailed error responses in dev
