# ============================================================================
# NatHacks Frontend - Environment Variables
#
# Copy this file to .env.local and configure for your environment
# For Docker Compose: Customize backend/.env and frontend/.env for auto-loading
# ============================================================================

# ── API Configuration ──────────────────────────────────────────────────────
# URLs for backend services. Docker Compose sets these automatically.
# For local dev: adjust to match your backend location.

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Application Settings ───────────────────────────────────────────────────

# NEXT_PUBLIC_APP_NAME=NatHacks Assistive Mirror
# NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ── Feature Flags (Optional) ───────────────────────────────────────────────

# NEXT_PUBLIC_ENABLE_VOICE_ASSIST=true
# NEXT_PUBLIC_ENABLE_AR_MARKERS=true
# NEXT_PUBLIC_ENABLE_CLOUD_VISION=true

# ── Build Configuration ────────────────────────────────────────────────────
# Disable telemetry for privacy

NEXT_TELEMETRY_DISABLED=1

# ── Environment Detection (Set by CI/Docker) ──────────────────────────────
# Set automatically; override only if needed

# NODE_ENV=production
