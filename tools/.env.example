# ============================================================================
# NatHacks Tools - Environment Variables
#
# Copy this file to .env and configure for your environment
# The Tools service (Nginx) primarily serves static content.
# ============================================================================

# ── Nginx Configuration ────────────────────────────────────────────────────

# NGINX_PORT=80              # Port to serve aruco-viewer (default: 80)
# NGINX_WORKERS=4            # Nginx worker processes

# ── Marker Viewer Settings (Optional) ──────────────────────────────────────

# MARKER_SIZE=200            # Generated marker size in pixels
# MARKER_DPI=150             # Print DPI for markers
